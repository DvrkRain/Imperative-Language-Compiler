type Cube is array [5] Matrix;

routine fillCube(c : Cube, value : integer) is
    var x : integer;
    var y : integer;
    var z : integer;
    
    for x in 1..3 loop
        for y in 1..3 loop
            for z in 1..3 loop
                c[x][y][z] := value * (x + y + z);
            end
        end
    end
end

